MARKET_S3_BUCKET=market-data-lake
MARKET_S3_REGION=us-east-1

MARKET_AIRFLOW_HOST_PORT=58080

VITE_API_BASE_URL=http://localhost:8000
VITE_API_KEY=
ALLOWED_ORIGINS=http://localhost:5173
ALLOWED_ORIGIN_REGEX=
MARKET_API_KEY=
MARKET_API_KEY_FILE=
MARKET_API_KEY_HEADER=x-api-key
MARKET_RATE_LIMIT_MAX_REQUESTS=120
MARKET_RATE_LIMIT_WINDOW_SECONDS=60
MARKET_LIVE_CACHE_TTL_MINUTES=15
MARKET_NEWS_CACHE_TTL_MINUTES=180
MARKET_NEWS_SUMMARY_CACHE_TTL_MINUTES=180
MARKET_ALLOW_STALE_CACHE_FALLBACK=true
MARKET_STARTUP_CHECK_MODE=warn
CORS_ALLOW_CREDENTIALS=true
