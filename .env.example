MARKET_HISTORY_INTERVAL=1h
MARKET_HISTORY_LOOKBACK_DAYS=30

MARKET_MINIO_API_HOST_PORT=59000
MARKET_MINIO_CONSOLE_HOST_PORT=59001
MARKET_MINIO_ROOT_USER=minioadmin
MARKET_MINIO_ROOT_PASSWORD=minioadmin
